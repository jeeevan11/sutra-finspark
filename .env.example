# SUTRA configuration — copy to .env (docker compose reads it automatically)

# Master seed: same seed = same world = same replay = same alerts.
SUTRA_SEED=42

# Bus: "redis" (docker / live demo) or "memory" (local dev without Redis).
SUTRA_BUS=redis
REDIS_URL=redis://redis:6379/0

# Where the backend keeps SQLite DB, PQC keys, trained ML model.
SUTRA_DATA_DIR=/app/data

# Frontend → backend base URL as seen from the *browser*.
NEXT_PUBLIC_API_BASE=http://localhost:8000
